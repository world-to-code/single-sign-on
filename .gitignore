# ---- Java / Gradle (sso-backend) ----
sso-backend/.gradle/
sso-backend/build/
.gradle/
build/

# ---- Node / Vite (sso-frontend) ----
sso-frontend/node_modules/
sso-frontend/dist/

# Generated SPA bundle (built by the frontend into the backend's static resources)
sso-backend/src/main/resources/static/

# ---- IDE ----
.idea/
*.iml
.vscode/
.project
.classpath
.settings/
.factorypath
bin/

# ---- Secrets & keystores ----
*.p12
*.jks
*.pem
.env
.env.*
# SOPS age PRIVATE keys — never commit (the PUBLIC key goes in .sops.yaml). Encrypted secrets/*.sops.yaml are safe.
age.key
*.agekey
keys.txt
# A decrypted secrets file must never be committed (encrypt in place, or use `sops exec-env`).
secrets/*.dec.yaml
secrets/prod.yaml

# ---- Runtime data (SAML keystore, etc.) ----
data/
sso-backend/data/

# ---- Generated SAML SP test config (per-deployment IdP cert; run scripts/setup_saml_test.py) ----
scripts/saml-sp/

# ---- Logs / misc ----
*.log
**/__pycache__/
